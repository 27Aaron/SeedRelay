# Copy this file before the first run:
# cp .env.example .env
#
# Local server settings. You may change these values.
host=127.0.0.1
port=8000
model=seed-asr

# Optional local OpenAI-compatible API key.
# Leave empty to disable API key checks.
api_key=

# Enable the embedded Web UI.
# Set to true to serve the web interface at http://host:port/
web=false

# Enable debug logging.
debug=false

# SeedRelay manages these values automatically after device registration.
# Do not edit this block manually unless you are intentionally replacing credentials.
device_id=
install_id=
cdid=
openudid=
clientudid=
token=
